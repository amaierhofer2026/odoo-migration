<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- side menu category -->
    <menuitem id="menu_finance_configuration" name="Configuration" parent="account.menu_finance"/>
    <!--START Action and Menuentry-->
    <record model="ir.actions.act_window" id="menu_finance_configuration_projectcategory_action">
        <field name="name">Project Category</field>
        <field name="res_model">itk_projectcategory.projectcategory</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">Create the first Project Category
            </p>
        </field>
    </record>

    <menuitem id="menu_finance_configuration_projectcategory" name="Project Category"
              parent="menu_finance_configuration"
              action="menu_finance_configuration_projectcategory_action"/>
    <!--END Action and Menuentry-->



       <!--START Treeview and Formview -->
        <record model="ir.ui.view" id="tree_view_projektcategory">
            <field name="name">itk_projectcategory.projectcategory.tree</field>
            <field name="model">itk_projectcategory.projectcategory</field>
            <field name="arch" type="xml">
                <tree string="Fields of Law">
                    <field name="name"/>
                    <field name="code"/>
                    <field name ="seq"/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="form_view_projektcategory">
            <field name="name">itk_projectcategory.projectcategory.form</field>
            <field name="model">itk_projectcategory.projectcategory</field>
            <field name="arch" type="xml">
                <form string="Project Category">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name ="seq"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <!--END Treeview and Formview -->



</odoo>
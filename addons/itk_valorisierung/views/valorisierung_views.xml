<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- side menu category -->
    <menuitem id="menu_finance_configuration" name="Configuration" parent="account.menu_finance"/>
    <!--START Action and Menuentry-->
    <record model="ir.actions.act_window" id="menu_finance_configuration_valorisierung_action">
        <field name="name">Valorisation Text</field>
        <field name="res_model">itk_valorisierung.valorisierung</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">Create the first Valorisation Text
            </p>
        </field>
    </record>

    <menuitem id="menu_finance_configuration_valorisierung" name="Valorisierung"
              parent="menu_finance_configuration"
              action="menu_finance_configuration_valorisierung_action"/>
    <!--END Action and Menuentry-->

       <!--START Treeview and Formview -->
        <record model="ir.ui.view" id="tree_view_valorisierung">
            <field name="name">itk_valorisierung.valorisierung.tree</field>
            <field name="model">itk_valorisierung.valorisierung</field>
            <field name="arch" type="xml">
                <list string="Valorisation Texts">
                    <field name="name"/>
                    <field name="description"/>
                    <field name ="seq"/>
                </list>
            </field>
        </record>

        <record model="ir.ui.view" id="form_view_valorisierung">
            <field name="name">itk_valorisierung.valorisierung.form</field>
            <field name="model">itk_valorisierung.valorisierung</field>
            <field name="arch" type="xml">
                <form string="Valorisation Text">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="description"/>
                            <field name ="seq"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <!--END Treeview and Formview -->

</odoo>

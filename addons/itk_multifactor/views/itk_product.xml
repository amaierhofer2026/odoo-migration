<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_product_template_tree_itk_multi_factor" model="ir.ui.view">
        <field name="name">Product Template Tree ITK (multifactor)</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='list_price']" position="before">
                <field name="is_multi_factor_product"/>
            </xpath>
        </field>
    </record>

    <record id="view_product_template_form_itk_multi_factor" model="ir.ui.view">
        <field name="name">Product Template ITK (multifactor)</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='list_price']" position="after">
                <field name="is_multi_factor_product"/>
            </xpath>
        </field>
    </record>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="subscription_set_pricelist_confirm_view" model="ir.ui.view">
        <field name="name">sale.subscription.set.pricelist.confirm.form</field>
        <field name="model">sale.subscription.set.pricelist.confirm</field>
        <field name="arch" type="xml">
            <form string="Set Pricelist for Subscriptions">
                <p class="oe_grey">This update is not reversible.</p>
                <group>
                    <field name="pricelist_id"/>
                </group>
                <footer>
                    <button string="Set Pricelist" name="subscription_set_pricelist" type="object" default_focus="1" class="btn-primary"/>
                    <button string="Cancel" class="btn-default" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <act_window id="action_subscription_set_pricelist_confirm" multi="True" key2="client_action_multi" name="Set Pricelist for Subscriptions" res_model="sale.subscription.set.pricelist.confirm" src_model="sale.subscription" view_mode="form" target="new"/>

</odoo>

        <!-- Tree-View -->
        <record id="view_product_template_tree_itk" model="ir.ui.view">
            <field name="name">Product Template Tree ITK</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_tree_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='type']" position="replace">
                    <field name="type" invisible="1"/>
                </xpath>
                <xpath expr="//field[@name='categ_id']" position="before">
                    <field name="product_type_id" string="Status"/>
                </xpath>
            </field>
        </record>
        <!-- Form-View -->
        <record id="view_product_template_form_itk" model="ir.ui.view">
            <field name="name">Product Template ITK</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='type']" position="replace">
                    <field name="type" invisible="1"/>
                </xpath>
                <xpath expr="//group[@name='group_general']/field[last()]" position="after">
                    <group string="Product-Typ" name="product_type">
                        <field name="product_type_id"/>
                    </group>
                    <group name="subscription" string="Subscription">
                        <field name="recurring_invoice"/>
                        <field name="subscription_template_id" invisible="not recurring_invoice"/>
                    </group>
                </xpath>
                <xpath expr="//group[@name='group_standard_price']/field[last()]" position="after">
                    <field name="to_multiply_by_factor"/>
                </xpath>
            </field>
        </record>


    </data>
</odoo>
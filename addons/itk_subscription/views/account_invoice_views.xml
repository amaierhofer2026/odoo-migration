<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_invoice_subscription_note_form" model="ir.ui.view">
        <field name="name">account.move.subscription.note</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_date']" position="after">
                <field name="sale_order_confirmation_date"/>
                <field name="sale_order_benefit_period"/>
                <field name="notice"/>
            </xpath>
        </field>
    </record>
</odoo>

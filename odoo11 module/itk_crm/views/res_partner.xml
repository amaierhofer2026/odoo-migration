<odoo>
    <data>
         <!--Search-View -->
        <record id="res_partner_searchview_customization_itk" model="ir.ui.view">
            <field name="field_parent" eval="False"/>
            <field name="groups_id" eval="[(6, 0, [])]"/>
            <field name="inherit_id" ref="base.view_res_partner_filter"/>
            <field name="mode">extension</field>
            <field name="model">res.partner</field>
            <field name="name">ITK: res.partner.select customization</field>
            <field name="priority">99</field>
            <field name="type">search</field>
            <field name="active" eval="True"/>
            <field name="arch" type="xml">
                <data>
                    <xpath expr="//search[1]/field[@name='name']" position="after">
                        <field name="display_name"/>
                        <field name="ref"/>
                    </xpath>
                    <xpath expr="//filter[@name='salesperson']" position="after">
                        <filter context="{'group_by': 'ref'}" name="title" string="Community Code"/>
                        <filter context="{'group_by': 'status_of_partner_id'}" name="title" string="Status"/>
                    </xpath>
                </data>
            </field>
        </record>
        <!-- Tree-View -->
        <record id="view_partner_itk_tree" model="ir.ui.view">
            <field name="name">res.partner.tree (itk)</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='display_name']" position="before">
                    <field name="ref" string="GKZ"/>
                </xpath>
                <xpath expr="//field[@name='email']" position="after">
                    <field name="user_id" string="Salesperson"/>
                    <field name="status_of_partner_id" string="Status"/>
                </xpath>
            </field>
        </record>
        <!-- Form-View -->
        <record id="view_partner_form_itk" model="ir.ui.view">
            <field name="name">res.partner.form (itk)</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">

                <!--<xpath expr="//button[@name='toggle_active']" position="before">-->
                <!--<button class="oe_stat_button" type="object" name="act_show_sales_as_final_customer"-->
                <!--icon="fa-usd"-->
                <!--help="Show Sales to Customer as Final Customer">-->
                <!--<field name="sales_as_final_customer_count" widget="statinfo" string="Sales Final Customer"/>-->
                <!--</button>-->
                <!--</xpath>-->

                <field name="company_name"
                       attrs="{'invisible': ['|', '|', ('company_name', '=', False), ('company_name', '=', ''), ('is_company', '=', True)]}"/>

                <xpath expr="//field[@name='name']" position="before">
                    <div style="width: 100%;">
                        <h1>
                            <field name="display_name"/>
                            <br/>
                        </h1>
                    </div>
                </xpath>


                <xpath expr="//field[@name='name']" position="replace">
                    <div class="oe_edit_only">
                        <h3>
                            <field name="name"
                                   attrs="{'invisible': [('is_company','=',False)]}"/>
                        </h3>

                    </div>
                </xpath>


                <xpath expr="//form[1]/sheet[1]/div[2]" position="after">
                    <group name="group_1" string="Characteristics">
                        <group name="group_1_left">
                            <field name="ref" attrs="{'invisible': [('is_company', '=', False)]}" string="GKZ"/>
                            <!--<field name="attention_of" attrs="{'invisible': [('is_company', '=', False)]}"/>-->
                            <field name="attention_of"/>
                            <field name="community_salutation" attrs="{'invisible': [('is_company', '=', False)]}"/>
                        </group>
                        <group name="group_1_right">
                             <field name="user_id"/>
                            <!--<field name="user_id" attrs="{'invisible': [('is_company', '=', False)]}"/>-->
                            <field name="supplier"/>
                            <field name="customer"/>
                            <!--<field name="status_of_partner_id" attrs="{'invisible': [('is_company', '=', False)]}"-->
                                   <!--widget="radio"/>-->
                            <field name="status_of_partner_id" widget="radio"/>
                            <!--<field name="reseller" attrs="{'invisible': [('is_company', '=', False)]}"/>-->


                        </group>
                    </group>
                </xpath>

                <xpath expr="//form[1]/sheet[1]/group[2]" position="replace">
                    <field name="type" attrs="{'invisible': [('parent_id','=', False)]}"
                           groups="base.group_no_one"/>
                    <group>
                        <group>
                            <label for="street" string="Address"/>
                            <div class="o_address_format">
                                <div class="oe_edit_only">
                                    <button name="open_parent" type="object" string="(edit)" class="oe_link"
                                            attrs="{'invisible': ['|', ('parent_id', '=', False), ('type', '!=', 'contact')]}"/>
                                </div>
                                <field name="street" placeholder="Street..." class="o_address_street"
                                       attrs="{'readonly': [('type', '=', 'contact'),('parent_id', '!=', False)]}"/>
                                <field name="street2" placeholder="Street 2..." class="o_address_street"
                                       attrs="{'readonly': [('type', '=', 'contact'),('parent_id', '!=', False)]}"/>
                                <field name="zip" placeholder="ZIP" class="o_address_zip"
                                       attrs="{'readonly': [('type', '=', 'contact'),('parent_id', '!=', False)]}"/>&amp;nbsp;
                                <field name="city" placeholder="City" class="o_address_city"
                                       attrs="{'readonly': [('type', '=', 'contact'),('parent_id', '!=', False)]}"/>


                                <field name="state_id" class="o_address_state" placeholder="State"
                                       options="{&quot;no_open&quot;: True}"
                                       attrs="{'readonly': [('type', '=', 'contact'),('parent_id', '!=', False)]}"
                                       context="{'country_id': country_id, 'zip': zip}"/>

                                <field name="country_id" placeholder="Country" class="o_address_country"
                                       options="{&quot;no_open&quot;: True, &quot;no_create&quot;: True}"
                                       attrs="{'readonly': [('type', '=', 'contact'),('parent_id', '!=', False)]}"/>
                            </div>
                            <field name="vat" placeholder="e.g. BE0477472701"
                                   attrs="{'readonly': [('parent_id','!=',False)]}"/>
                            <field name="category_id" widget="many2many_tags"
                                   options="{'color_field': 'color', 'no_create_edit': True}" placeholder="Tags..."/>
                        </group>
                        <group>
                            <field name="function" placeholder="e.g. Sales Director"
                                   attrs="{'invisible': [('is_company','=', True)]}"/>
                            <field name="phone" widget="phone"/>
                            <field name="mobile" widget="phone"/>
                            <field name="user_ids" invisible="1"/>
                            <field name="email" widget="email" context="{'gravatar_image': True}"
                                   attrs="{'required': [('user_ids','!=', [])]}"/>
                            <field name="official_email" widget="email"
                                   attrs="{'invisible': [('is_company', '=', False)]}"/>
                            <field name="website" widget="url" placeholder="e.g. www.odoo.com"/>
                            <field name="salutation" attrs="{'invisible': [('is_company', '=', True)]}"/>
                            <field name="title_put_in_front" attrs="{'invisible': [('is_company', '=', True)]}"/>
                            <field name="title" options="{&quot;no_open&quot;: True}"
                                   attrs="{'invisible': [('is_company', '=', True)]}"/>
                            <field name="title_put_in_back" attrs="{'invisible': [('is_company', '=', True)]}"/>
                            <field name="lang"/>
                        </group>
                    </group>
                </xpath>

                <!--<xpath expr="//field[@name='customer']" position="after">-->
                    <!--<field name="reseller" attrs="{'invisible': [('is_company', '=', False)]}"/>-->
                    <!--<field name="user_id" attrs="{'invisible': [('is_company', '=', False)]}"/>-->
                <!--</xpath>-->

                <notebook position="inside">
                    <page attrs="{'invisible': [('is_company', '=', False)]}" string="Community Information">
                        <group name="container_row_3">
                            <group string="Population" name="population">
                                <field name="population" attrs="{'invisible': [('is_company', '=', False)]}"/>
                                <!--<field name="multi_factor"-->
                                <!--attrs="{'invisible': [('is_company', '=', False)]}"/>-->
                                <field name="community_magnitude"
                                       attrs="{'invisible': [('is_company', '=', False)]}"/>

                                <!--<field name="population_thousands_factor"-->
                                       <!--attrs="{'invisible': [('is_company', '=', False)]}"/>-->


                                <field name="population_update"
                                       attrs="{'invisible': [('is_company', '=', False)]}"/>
                            </group>
                            <group>
                                <group string="Other" name="other">
                                    <field name="status_of_community"
                                           attrs="{'invisible': [('is_company', '=', False)]}"/>
                                    <field name="member_of_city_alliance"
                                           attrs="{'invisible': [('is_company', '=', False)]}"/>
                                </group>
                            </group>
                        </group>
                    </page>
                </notebook>
            </field>
        </record>
    </data>
</odoo>
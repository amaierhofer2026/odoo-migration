<odoo>
    <data>
        <!-- Quotation Search-View -->
        <record id="quotation_searchview_customization_itk" model="ir.ui.view">
            <field name="field_parent" eval="False"/>
            <field name="groups_id" eval="[(6, 0, [])]"/>
            <field name="inherit_id" ref="sale.sale_order_view_search_inherit_quotation"/>
            <field name="mode">extension</field>
            <field name="model">sale.order</field>
            <field name="name">ITK: sale.quotation.select customization</field>
            <field name="priority">99</field>
            <field name="type">search</field>
            <field name="active" eval="True"/>
            <field name="arch" type="xml">
                <data>
                    <xpath expr="//search[1]/field[@name='name']" position="after">
                        <field name="final_customer_id"/>
                        <field name="product_category_id"/>
                    </xpath>
                    <xpath expr="//filter[@name='customer']" position="after">
                        <filter context="{'group_by': 'final_customer_id'}" name="title" string="Final Customer"/>
                        <filter context="{'group_by': 'product_category_id'}" name="title" string="Product Category"/>
                    </xpath>
                </data>
            </field>
        </record>
        <!-- Quotation Tree-View -->
        <record id="view_quotation_itk_tree" model="ir.ui.view">
            <field name="name">sale.order.tree (itk)</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_quotation_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='date_order']" position="attributes">
                    <attribute name="widget">date</attribute>
                </xpath>
                <xpath expr="//field[@name='partner_id']" position="after">
                    <field name="partner_invoice_id"/>
                    <field name="sale_contact_id"/>
                    <field name="administrative_contact_id"/>
                    <field name="technical_contact_id"/>
                </xpath>

                 <xpath expr="//field[@name='amount_total']" position="before">
                   <field name="amount_untaxed" sum="Total Net" widget="monetary"/>
                    <!--<field name="product_category_id"/>-->
                </xpath>
                 <xpath expr="//field[@name='amount_total']" position="replace">
                   <!--<field name="amount_total" sum="Total Net" widget="monetary"/>-->
                    <!--<field name="product_category_id"/>-->
                </xpath>
            </field>
        </record>


        <!-- SaleOrder Search-View -->
        <record id="saleorder_searchview_customization_itk" model="ir.ui.view">
            <field name="field_parent" eval="False"/>
            <field name="groups_id" eval="[(6, 0, [])]"/>
            <field name="inherit_id" ref="sale.sale_order_view_search_inherit_sale"/>
            <field name="mode">extension</field>
            <field name="model">sale.order</field>
            <field name="name">ITK: sale.order.select customization</field>
            <field name="priority">99</field>
            <field name="type">search</field>
            <field name="active" eval="True"/>
            <field name="arch" type="xml">
                <data>
                    <xpath expr="//search[1]/field[@name='name']" position="after">
                        <!--<field name="final_customer_id"/>-->
                        <field name="product_category_id"/>
                    </xpath>
                    <xpath expr="//filter[@name='customer']" position="after">
                        <filter context="{'group_by': 'final_customer_id'}" name="title" string="Final Customer"/>
                        <filter context="{'group_by': 'product_category_id'}" name="title" string="Product Category"/>
                    </xpath>
                </data>
            </field>
        </record>
        <!-- SaleOrder Tree-View -->
        <record id="view_order_itk_tree" model="ir.ui.view">
            <field name="name">sale.order.tree (itk)</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='confirmation_date']" position="attributes">
                    <attribute name="widget">date</attribute>
                </xpath>
                <xpath expr="//field[@name='partner_id']" position="after">
                    <field name="partner_invoice_id"/>
                    <field name="sale_contact_id"/>
                    <!--<field name="administrative_contact_id"/>-->
                    <!--<field name="technical_contact_id"/>-->
                    <!--<field name="product_category_id"/>-->
                </xpath>
                <xpath expr="//field[@name='amount_total']" position="before">
                   <field name="amount_untaxed" sum="Total Net" widget="monetary"/>
                    <!--<field name="product_category_id"/>-->
                </xpath>
                 <xpath expr="//field[@name='amount_total']" position="replace">
                   <!--<field name="amount_total" sum="Total Net" widget="monetary"/>-->
                    <!--<field name="product_category_id"/>-->
                </xpath>
            </field>
        </record>


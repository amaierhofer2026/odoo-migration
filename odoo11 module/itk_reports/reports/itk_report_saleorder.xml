<odoo>
    <data>
        <template id="sale.report_itk_saleorder_document">
            <t t-call="web.external_layout">
                <t t-set="doc" t-value="doc.with_context({'lang':doc.partner_id.lang})"/>
                <!--START: Einschub  für neuen Style für Info-Teil-->

                <style>
* {
  box-sizing: border-box;
}

/* Create two equal columns that floats next to each other */
.column70 {
  float: left;
  width: 70%;
  padding-right: 5px;
  vertical-align: top;
    text-align: left;
  background-color: transparent;

}
.column30 {
  float: left;
  width: 30%;
  padding-right: 5px;
  vertical-align: top;
    text-align: left;
  background-color: transparent;

}



/* Clear floats after the columns */
.row:after {
  content: "";
  display: table;
  clear: both;
}
                </style>
                <!--ENDE: Einschub  für neuen Style für Info-Teil-->




                <div class="page">
                    <form>
                        <div class="container" style="line-height: 50%;padding-bottom:3em;padding-top:10em">

                            <div class="row " style="padding-bottom:1em; font-size:15px; padding-top:3em;">

                                <div class="col-xs-10 small first-page" name="company_address">
                                    <u>
                                        <span t-field="doc.company_id.partner_id.name"/>
                                        <font color="#000000">,</font>
                                        <span t-field="doc.company_id.partner_id.zip"/>
                                        <span t-field="doc.company_id.partner_id.city"/>
                                        <font color="#000000">,</font>
                                        <span t-field="doc.company_id.partner_id.street"/>
                                    </u>
                                </div>

                            </div>
                            <style>
                                table.padd5 {
                                border: 1px solid yellow;
                                cellspacing: 1;
                                border-spacing: 0;
                                }
                            </style>
                            <style>
                                p.padding5 {
                                border: 1px solid red;
                                }
                            </style>

                            <style>
                                td.padding5 {

                                }
                            </style>
                            <div class="row">
                                <div class="col-xs-9 text-left;font-size: 16px;">
                                    <table style="text-align: left; width: 60%; height: 36px; font-size: 16px;" border="1" cellpadding="2" cellspacing="2">
                                        <tbody>
                                            <tr>
                                                <td style="vertical-align: top;">
                                                    <t t-esc="doc.partner_id.community_salutation"/>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="vertical-align: top;">
                                                <span t-if="doc.sale_contact_id.attention_of">Zu Handen </span>
                                                    <!--<span>Zu Handen </span>-->
                                                    <t t-esc="doc.sale_contact_id.attention_of"/>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="vertical-align: top;">
                                                    <t t-esc="doc.partner_id.street"/>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="vertical-align: top;">
                                                    <t t-esc="doc.partner_id.street2"/>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="vertical-align: top;">
                                                    <t t-esc="doc.partner_id.zip"/>
                                                    <t t-esc="doc.partner_id.city"/>
                                                </td>
                                            </tr>
                                            <!--<tr>-->
                                            <!--<td style="vertical-align: top;">-->
                                            <!--<t t-esc="doc.partner_id.country_id.name"/>-->
                                            <!--</td>-->
                                            <!--</tr>-->
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            <div class="row mt8">
                                <div class="col-xs-9 text-left"/>
                                <div class="col-xs-1">
                                    <ul class="list-inline pagenumber pull-right text-right">
                                        <li>
                                            <strong>
                                                <span class="page"/>
                                            </strong>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </form>
                    <div class="container" style="line-height: 50%;padding-bottom:1em;padding-top:1em">
                        <div class="row mt8">
                            <div class="col-xs-6 text-left"/>
                            <div class="col-xs-6 pull-right text-right">
                                <div style="font-size: 16px;">
                                    <strong>
                                        <!--<t t-if="not (env.context.get('proforma', False) or is_pro_forma)">-->
                                        <!--<span t-if="doc.state not in ['draft','sent']">Auftragsdatum</span>-->
                                        <!--<span t-if="doc.state in ['draft','sent']">Angebotsdatum</span>-->
                                        <!--</t>-->
                                        <!--<t t-if="env.context.get('proforma', False) or is_pro_forma">-->
                                        <!--<span>Datum Proformarechnung</span>-->
                                        <!--</t>-->
                                        <span t-field="doc.date_order" t-field-options='{"format": "dd.MM.YYYY"}'/>
                                    </strong>
                                </div>
                            </div>
                        </div>
                        <div class="row mt8">
                            <div class="col-xs-9 text-left"/>
                            <div class="col-xs-1">
                                <ul class="list-inline pagenumber pull-right text-right">
                                    <li>
                                        <strong>
                                            <span class="page"/>
                                        </strong>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <!-- <h5> -->
                    <div style="font-size: 16px;">
                        <strong>
                            <t t-if="not (env.context.get('proforma', False) or is_pro_forma)">
                                <span t-if="doc.state not in ['draft','sent']">Auftrag</span>
                                <span t-if="doc.state in ['draft','sent']">Angebot</span>
                            </t>
                            <t t-if="env.context.get('proforma', False) or is_pro_forma">
                                <span>Proformarechnung</span>
                                <!--<t t-esc="doc.confirmation_date"/>-->
                            </t>
                            <span t-field="doc.name"/>
                        </strong>
                    </div>
                    <!-- </h5> -->

                        <!--START: Einschub  für neuen Info-Teil-->
                        <div class="container" style="line-height: 50%;padding-bottom:1em;padding-top:5em">

                            <!-- <div class="row mt8"> -->
                            <div class="column70">
                                <table style="max-width: 100%; font-size: 16px; padding-bottom:3em cellpadding=2 border=0">
                                    <colgroup>
                                        <col style="width: 10%;" span="1"/>
                                        <col style="max-width: 90%;" span="1"/>
                                    </colgroup>
                                    <tbody>
                                        <tr style="opacity: 0.0;">
                                            <td><strong>e </strong></td>
                                            <td style="padding-left: 5px; text-align: left;">
                                               <!-- <t t-esc="doc.projectcategory_id.name"/>
                                            -->
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><strong> </strong></td>
                                            <td style="padding-left: 5px; text-align: left;">
                                                <!--<span t-field="doc.sale_order_confirmation_date" t-field-options='{"format": "dd.MM.YYYY"}'/>
                                           -->
                                            </td>
                                        </tr>
                                        
                                        <tr>
                                            <td><strong> </strong></td>
                                            <td style="padding-left: 5px; text-align: left;">
                                               <!-- <span t-field="doc.sale_order_benefit_period" t-field-options='{"format": "YYYY"}'/>
                                            --> 
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <div class="column30" style="">
                                <table style="width: 100%;  font-size: 16px;" border="0">
                                    <colgroup>
                                        <col style="width: 10%;" span="1"/>
                                        <col style="max-width: 90%;" span="1"/>
                                    </colgroup>
                                    <tbody>
                                        <tr>
                                            <td> <strong>Zahlung:</strong></td>
                                            <td style="padding-left: 5px; text-align: left;">
                                                <t t-esc="doc.payment_term_id.name"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><strong>Bearbeiter/in:</strong></td>
                                            <td style="padding-left: 5px; text-align: left;">
                                                <t t-esc="doc.user_id.name"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><strong>Währung:</strong></td>
                                            <td style="padding-left: 5px; text-align: left;">
                                                <t t-esc="doc.currency_id.name"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><strong>Ihre UID-Nr.:</strong></td>
                                            <td style="padding-left: 5px; text-align: left;">
                                                <t t-esc="doc.partner_id.vat"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <!--ENDE: Einschub  für neuen Info-Teil-->

                    <div style="padding-bottom:1em font-size: 16px;"/>
                    <t t-if="not (env.context.get('proforma', False) or is_pro_forma)">
                        <div style="font-size: 16px;">
                            <span t-if="doc.state not in ['draft','sent']">Hiermit bestätigen wir die Beauftragung der
                            Leistungen gemäß Angebot.
                            </span>
                            <span t-if="doc.state in ['draft','sent']">Folgend dürfen wir Ihnen die angefragte und
                            abgestimmte Leistung anbieten:
                            </span>
                        </div>
                    </t>
                    <div style="padding-bottom: 1em"/>
                    <t t-set="display_discount" t-value="any([l.discount for l in doc.order_line])"/>
                    <t t-foreach="doc.order_lines_layouted()" t-as="page">
                        <table style="width:100%">
                            <thead class="active">
                                <tr>
                                    <th style="font-weight: bold; border-bottom: 1px solid black;padding-bottom:0,5em; background-color:#bbbbbb;padding-left:5px;">
                                        Pos
                                    </th>
                                    <th style="font-weight: bold; border-bottom: 1px solid black;padding-bottom:0,5em; background-color:#bbbbbb;padding-left:5px;">
                                        Leistungsgegenstand
                                    </th>
                                    <th class="text-right" style="font-weight: bold; border-bottom: 1px solid black;padding-bottom:0,5em;background-color:#bbbbbb;padding-left:5px;">
                                        Menge
                                    </th>
                                    <th class="text-right" style="font-weight: bold; border-bottom: 1px solid black;padding-bottom:0,5em; background-color:#bbbbbb;padding-left:5px;">
                                        Einzelpreis
                                    </th>
                                    <th t-if="display_discount" class="text-right" groups="sale.group_discount_per_so_line" style="font-weight: bold; border-bottom: 1px solid black; background-color:#bbbbbb;">
                                        Rabatt
                                    </th>
                                    <!--<th width="8%" class="text-right"-->
                                    <!--style="font-weight: bold; border-bottom: 1px solid black; background-color:#bbbbbb;">Steuern-->
                                    <!--</th>-->
                                    <!--<th class="text-right" groups="sale.group_show_price_subtotal"-->
                                    <!--style="font-weight: bold; border-bottom: 1px solid black; background-color:#bbbbbb;">-->
                                    <!--Preis-->
                                    <!--</th>-->
                                    <th class="text-right" style="font-weight: bold; border-bottom: 1px solid black;padding-bottom:0,5em;  background-color:#bbbbbb;padding-left:5px;padding-right:5px;">
                                        Gesamtpreis
                                    </th>
                                </tr>
                            </thead>
                            <tbody class="sale_tbody" style="font-size: 16px;">
                                <!--<t t-foreach="page" t-as="layout_category">-->
                                <!--<t t-if="layout_category_size &gt; 1 or page_size &gt; 1"-->
                                <!--groups="sale.group_sale_layout">-->
                                <!--<tr class="active">-->
                                <!--<td colspan="7" style="font-weight: bold; border-bottom: 1px solid black;">-->
                                <!--<t t-esc="layout_category['name']"/>-->
                                <!--</td>-->
                                <!--</tr>-->
                                <!--</t>-->
                                <tr t-foreach="doc.order_line" t-as="l" style="font-size: 16px; border-bottom:1em solid #ffffff; border-top:1em solid #ffffff;">
                                    <td style="padding-left:5px;">
                                        <!--<span>Position</span>-->
                                        <span t-field="l.number"/>
                                    </td>
                                    <td style="padding-left:5px;">
                                        <span t-field="l.name"/>
                                    </td>
                                    <td class="text-right" style="padding-left:5px;padding-right:5px;">
                                        <span t-field="l.product_uom_qty"/>
                                        <span t-field="l.product_uom" groups="product.group_uom"/>
                                    </td>
                                    <td class="text-right" style="padding-left:5px;padding-right:5px;">
                                        <span t-field="l.price_unit" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: doc.pricelist_id.currency_id}"/>
                                    </td>
                                    <td t-if="display_discount" class="text-right" groups="sale.group_discount_per_so_line">
                                        <span t-field="l.discount"/>
                                        <span>%</span>
                                    </td>
                                    <!--<td class="text-right">-->
                                    <!--<span t-esc="', '.join(map(lambda x: (x.description or x.name), l.tax_id))"/>-->
                                    <!--</td>-->
                                    <td class="text-right" groups="sale.group_show_price_subtotal" style="padding-left:5px;padding-right:5px;">
                                        <span t-field="l.price_subtotal" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: doc.pricelist_id.currency_id}"/>
                                    </td>
                                    <!--<td class="text-right" groups="sale.group_show_price_total">-->
                                    <!--<span t-field="l.price_total"-->
                                    <!--t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: doc.pricelist_id.currency_id}"/>-->
                                    <!--</td>-->
                                    <!--</tr>-->
                                    <!--<tr>-->
                                    <!--<td colspan="7" width="100%" valign="top"-->
                                    <!--style="border-bottom: 1px solid darkgrey;">-->
                                    <!--<span t-field="l.name"/>-->
                                    <!--</td>-->
                                    <!--</tr>-->
                                </tr>
                                <!--<t t-if="(layout_category_size &gt; 1 or page_size &gt; 1) and layout_category['subtotal']"-->
                                <!--groups="sale.group_sale_layout">-->
                                <!--<tr class="text-right">-->
                                <!--<td colspan="6">-->
                                <!--<strong>Nettosumme</strong>-->
                                <!--<t t-set="subtotal"-->
                                <!--t-value="sum(line.price_subtotal for line in layout_category['lines'])"/>-->
                                <!--<span t-esc="subtotal"-->
                                <!--t-options="{'widget': 'monetary', 'display_currency': doc.pricelist_id.currency_id}"/>-->
                                <!--</td>-->
                                <!--</tr>-->
                                <!--</t>-->
                                <!--</t>-->
                            </tbody>
                        </table>
                        <t t-if="page_index &lt; page_size - 1" groups="sale.group_sale_layout">
                            <p style="page-break-before:always;"/>
                        </t>
                    </t>
                    <div class="clearfix">
                        <div class="row" name="total" style="font-size: 16px;">
                            <div class="col-xs-4 pull-right">
                                <table class="table table-condensed" style="min-width: 200px;max-width: 850px;">
                                    <tr class="border-black" style="border-bottom:1px solid #dddddd;">
                                        <td>
                                            Nettosumme
                                                                                                                                                                                                                                                                        <!--<strong>Nettosumme</strong>-->
                                        </td>
                                        <td class="text-right">
                                            <span t-field="doc.amount_untaxed" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: doc.pricelist_id.currency_id}"/>
                                        </td>
                                    </tr>
                                    <t t-foreach="doc._get_tax_amount_by_group()" t-as="amount_by_group">
                                        <tr style="border-bottom:1px solid #dddddd;">
                                            <t t-if="amount_by_group[3] == 1 and doc.amount_untaxed == amount_by_group[2]">
                                                <td>
                                                    <span t-esc="amount_by_group[0]"/>
                                                    <span>&amp;nbsp;
                                                        <span>auf</span>&amp;nbsp;
                                                        <t t-esc="amount_by_group[2]" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: doc.pricelist_id.currency_id}"/>
                                                    </span>
                                                </td>
                                                <td class="text-right">
                                                    <span t-esc="amount_by_group[1]" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: doc.pricelist_id.currency_id}"/>
                                                </td>
                                            </t>
                                            <t t-else="">
                                                <td>
                                                    <span t-esc="amount_by_group[0]"/>
                                                </td>
                                                <td class="text-right">
                                                    <span t-esc="amount_by_group[1]" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: doc.pricelist_id.currency_id}"/>
                                                </td>
                                            </t>
                                        </tr>
                                    </t>
                                    <tr class="border-black">
                                        <td>
                                            <strong>Gesamtsumme</strong>
                                        </td>
                                        <td class="text-right">
                                            <span t-field="doc.amount_total" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: doc.pricelist_id.currency_id}"/>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                    </div>
                    <t t-if="not (env.context.get('proforma', False) or is_pro_forma)">
                        <div style="font-size: 16px;">
                            <span t-if="doc.state not in ['draft','sent']">Wir bedanken uns für Ihre Beauftragung und
                            sichern Ihnen
                            die partnerschaftliche Ausführung der Leistungen zu.
                            </span>
                            <span t-if="doc.state in ['draft','sent']">Über eine Beauftragung und die Möglichkeit zur
                            Durchführung
                            würden wir uns sehr freuen und können Ihnen bereits heute eine hochwertige und
                            partnerschaftliche
                            Umsetzung garantieren.
                            </span>
                        </div>
                    </t>
                    <div style="padding-top:3em"/>
                    <p t-field="doc.note"/>
                    <p t-if="doc.payment_term_id.note">
                        <span t-field="doc.payment_term_id.note"/>
                    </p>
                    <p id="fiscal_position_remark" t-if="doc.fiscal_position_id and doc.fiscal_position_id.note">
                        <strong>Steuerzuordnungshinweis:</strong>
                        <span t-field="doc.fiscal_position_id.note"/>
                    </p>
                    <div class="oe_structure"/>
                </div>
            </t>
        </template>

        <template id="sale.report_itk_saleorder">

            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="sale.report_itk_saleorder_document" t-lang="doc.partner_id.lang"/>
                </t>
            </t>
        </template>

        <template id="sale.report_itk_saleorder_proforma">

            <t t-call="web.html_container">
                <t t-set = "is_pro_forma" t-value="True"/>
                <t t-foreach="docs" t-as="doc">
                    <t t-call="sale.report_itk_saleorder_document" t-lang="doc.partner_id.lang"/>
                </t>
            </t>
        </template>
    </data>
</odoo>

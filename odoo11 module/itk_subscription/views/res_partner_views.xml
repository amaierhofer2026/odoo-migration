    <!-- SmartButton for Subscriptions -->


    <record id="sale_subscription_action_res_partner" model="ir.actions.act_window">
        <field name="context">{'search_default_partner_id': [active_id], 'default_partner_id': active_id, 'group_by':'analytic_account_id'}</field>
        <field name="name">Subscriptions</field>
        <field name="res_model">sale.subscription.line</field>
        <!--AV-->
        <field name="view_type">form</field>
        <!--<field name="context">{'group_by':'analytic_account_id'}</field>-->
        <field name="view_mode">tree,form</field>
        <!--<field name="domain">[('active', '=', True)]</field>-->
        <!--AV-->
    </record>

    <record model="ir.ui.view" id="res_partner_view_inherit_sale_subscription">
        <field name="name">partner.view.button.subscriptions_count</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="priority" eval="22"/>
        <field name="groups_id" eval="[(4, ref('itk_subscription.group_sale_subscription_view'))]"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='toggle_active']" position="before">
                <button class="oe_stat_button" type="action"
                        name="%(itk_subscription.sale_subscription_action_res_partner)d"
                        icon="fa-book">
                    <field string="Subscriptions" name="subscription_count" widget="statinfo"/>
                </button>
            </xpath>
        </field>
    </record>

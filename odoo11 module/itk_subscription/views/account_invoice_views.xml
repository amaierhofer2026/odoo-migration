<?xml version="1.0" encoding="utf-8"?>
<odoo>
     <record id="view_account_invoice_subscription_note_form" model="ir.ui.view">
        <field name="name">account.invoice.subscription.note</field>
        <field name="model">account.invoice</field>
        <field name="inherit_id" ref="account.invoice_form"/>
        <field name="arch" type="xml">
        <xpath expr="//field[@name='cash_rounding_id']" position="replace">
                <field name="sale_order_benefit_period"/>
            </xpath>
           <xpath expr="//field[@name='comment']" position="after">
               <label string="Invoice Notice:"/><br/>
                <field name="notice"/>
                </xpath>
         </field>
     </record>
</odoo>

<odoo>
    <data>
        <template id="purchase.report_itk_purchaseorder_document">
            <t t-call="web.external_layout">
                <t t-set="doc" t-value="doc.with_context({'lang':doc.partner_id.lang})"/>
                <div class="page">
                    <form>
                        <div class="container" style="line-height: 50%;padding-bottom:3em;padding-top:10em">

                            <div class="row" style="padding-bottom:1em; font-size:10px;padding-top:3em;">
                                <div class="col-xs-10 small first-page text-left" name="company_address">
                                    <u>
                                        <span t-field="doc.company_id.partner_id.name"/>
                                        <font color="#215083">◼</font>
                                        <span t-field="doc.company_id.partner_id.zip"/>
                                        <span t-field="doc.company_id.partner_id.city"/>
                                        <font color="#215083">◼</font>
                                        <span t-field="doc.company_id.partner_id.street"/>
                                    </u>
                                </div>
                            </div>


                            <div class="row" style="padding-bottom:1em;padding-top:1em;">
                                <div class="col-xs-9 text-left">
                                    <table style="text-align: left; width: 60%; height: 36px; font-size: 16px;"
                                           border="1"
                                           cellpadding="2"
                                           cellspacing="2">
                                        <tbody>
                                            <tr>
                                                <td style="vertical-align: top;">
                                                    <t t-esc="doc.partner_id.parent_id.name"/>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="vertical-align: top;">
                                                    <t t-esc="doc.partner_id.name"/>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="vertical-align: top;">
                                                    <t t-esc="doc.partner_id.street"/>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="vertical-align: top;">
                                                    <t t-esc="doc.partner_id.street2"/>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="vertical-align: top;">
                                                    <t t-esc="doc.partner_id.zip"/>
                                                    <t t-esc="doc.partner_id.city"/>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="vertical-align: top;">
                                                    <t t-esc="doc.partner_id.country_id.name"/>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                                <div class="row mt8">
                                    <div class="col-xs-9 text-left"/>
                                    <div class="col-xs-1">
                                        <ul class="list-inline pagenumber pull-right text-right">
                                            <li>
                                                <strong>
                                                    <span class="page"/>
                                                </strong>
                                            </li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                    <div class="container" style="line-height: 50%;padding-bottom:1em;padding-top:1em">
                        <div class="row mt8">
                            <div class="col-xs-6 text-left"/>
                            <div class="col-xs-6 pull-right text-right">
                                <h5>
                                    <strong>
                                        <span>Bestelldatum</span>
                                        <span t-field="doc.date_order" t-field-options='{"format": "dd.MM.YYYY"}'/>
                                    </strong>
                                </h5>
                            </div>
                        </div>
                        <div class="row mt8">
                            <div class="col-xs-9 text-left"/>
                            <div class="col-xs-1">
                                <ul class="list-inline pagenumber pull-right text-right">
                                    <li>
                                        <strong>
                                            <span class="page"/>
                                        </strong>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div style=" font-size: 16px;">
                        <strong>
                            <span>Bestellung</span>
                            <span t-field="doc.name"/>
                        </strong>
                    </div>
                    <div style="padding-top:3em;font-size: 16px;"/>
                    <div style="font-size: 16px;">
                        <span>Hiermit bestellen wir nachfolgend aufgeführte Artikel zu den genannten Konditionen
                            und den genannten Lieferzeitpunkten.
                        </span>
                    </div>
                    <div style="padding-bottom:2em"/>

                    <table class="active" style="width: 100%; font-size: 16px;">
                        <thead class="active">
                            <tr>
                                <th class="text-center"
                                    style="font-weight: bold; border-bottom: 1px solid black; width: 5%; background-color:#bbbbbb;">
                                    <strong>Pos</strong>
                                </th>
                                <th style="font-weight: bold; border-bottom: 1px solid black; width: 35%; background-color:#bbbbbb;">
                                    <strong>Leistungsgegenstand</strong>
                                </th>

                                <th class="text-center"
                                    style="font-weight: bold; border-bottom: 1px solid black; width: 10%; background-color:#bbbbbb;">
                                    <strong>Lieferdatum</strong>
                                </th>
                                <th class="text-right"
                                    style="font-weight: bold; border-bottom: 1px solid black; width: 10%; background-color:#bbbbbb;">
                                    <strong>Menge</strong>
                                </th>
                                <th class="text-right"
                                    style="font-weight: bold; border-bottom: 1px solid black; width: 10%; background-color:#bbbbbb;">
                                    <strong>Einzelpreis</strong>
                                </th>
                                <th class="text-center"
                                    style="font-weight: bold; border-bottom: 1px solid black; width: 15%; background-color:#bbbbbb;">
                                    <strong>Steuern</strong>
                                </th>
                                <th class="text-right"
                                    style="font-weight: bold; border-bottom: 1px solid black; width: 15%; background-color:#bbbbbb;">
                                    <strong>Gesamtpreis</strong>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="doc.order_line" t-as="line">
                                <td class="text-center">
                                    <span t-field="line.number"/>
                                </td>
                                <td>
                                    <span t-field="line.name"/>
                                </td>

                                <td class="text-center">
                                    <span t-field="line.date_planned" t-field-options='{"format": "dd.MM.YYYY"}'/>
                                </td>
                                <td class="text-right">
                                    <span t-field="line.product_qty"/>
                                    <span t-field="line.product_uom.name" groups="product.group_uom"/>
                                </td>
                                <td class="text-right">
                                    <span t-field="line.price_unit"/>
                                </td>
                                <td>
                                    <span t-esc="', '.join(map(lambda x: x.name, line.taxes_id))"/>
                                </td>
                                <td class="text-right">
                                    <span t-field="line.price_subtotal"
                                          t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="row">
                        <div class="col-xs-4 pull-right">
                            <table class="table table-condensed" style="font-size: 16px;">
                                <tr class="border-black">
                                    <td>
                                        <strong>Nettosumme</strong>
                                    </td>
                                    <td class="text-right">
                                        <span t-field="doc.amount_untaxed"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Steuern</td>
                                    <td class="text-right">
                                        <span t-field="doc.amount_tax"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                </tr>
                                <tr class="border-black">
                                    <td>
                                        <strong>Gesamtsumme</strong>
                                    </td>
                                    <td class="text-right">
                                        <span t-field="doc.amount_total"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>


                    <div style="padding-top:3em"/>
                    <div style="font-size: 16px;">
                        <span>Wir bitten um Lieferung zu den genannten Zeitpunkten.</span>
                        <div style="padding-top:3em"/>
                        <p t-field="doc.notes"/>
                    </div>
                    <div style="padding-top:3em"/>
                    <div style="font-size: 16px;">
                        <span>
                            Ihr Team von
                            <br/>
                            IT-Kommunal GmbH
                            <br/>
                            <br/>
                            www.it-kommunal.at
                        </span>

                        <!--</div>-->
                    </div>
                    <div class="oe_structure"/>
                </div>
            </t>
        </template>


        <template id="purchase.report_itk_purchaseorder">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="purchase.report_itk_purchaseorder_document" t-lang="doc.partner_id.lang"/>
                </t>
            </t>
        </template>
    </data>
</odoo>

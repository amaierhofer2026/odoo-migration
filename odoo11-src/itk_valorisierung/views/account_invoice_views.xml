<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_itk_valorisierung_valorisierung_form" model="ir.ui.view">
        <field name="name">account.invoice.valorisierung</field>
        <field name="model">account.invoice</field>
        <field name="inherit_id" ref="itk_subscription.view_account_invoice_subscription_note_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='notice']" position="after">
                <group>
                    <field name="valorisierung_id"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
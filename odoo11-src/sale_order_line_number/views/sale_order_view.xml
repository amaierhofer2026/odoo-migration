<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_form_line_number" model="ir.ui.view">
        <field name="name">sale.order.form.line.number</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/list/field[@name='sequence']" position="after">
                <field name="number" string="Line NO."/>
            </xpath>
        </field>
    </record>
</odoo>
